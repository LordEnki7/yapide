modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "server-health"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-assets"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-deployment"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "pre-push"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/que-lo-que exec tsc --noEmit 2>&1 | head -30 && pnpm --filter @workspace/api-server exec tsc --noEmit 2>&1 | head -30"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "server-health"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "curl -sf http://localhost:${PORT:-8080}/api/health && curl -sf http://localhost:${PORT:-8080}/api/version && echo 'API healthy'"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check-assets"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ls artifacts/que-lo-que/public/logo.png artifacts/que-lo-que/public/manifest.json artifacts/que-lo-que/public/sw.js artifacts/que-lo-que/public/icons/icon-192.png && echo 'All public assets present'"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check-deployment"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "curl -sf https://yapide.app/api/version | grep serverTime && echo 'Production is live'"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "pre-push"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/pre-push-check.sh"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 4200

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 8085
externalPort = 6800

[[ports]]
localPort = 8086
externalPort = 8008

[[ports]]
localPort = 8087
externalPort = 8080

[[ports]]
localPort = 21512
externalPort = 3000

[[ports]]
localPort = 21513
externalPort = 3001

[[ports]]
localPort = 21514
externalPort = 5000

[[ports]]
localPort = 21515
externalPort = 3003

[[ports]]
localPort = 21516
externalPort = 6000

[[ports]]
localPort = 21517
externalPort = 8099

[[ports]]
localPort = 21518
externalPort = 8000

[[ports]]
localPort = 21519
externalPort = 9000

[userenv]

[userenv.production]
SESSION_COOKIE_DOMAIN = ".yapide.app"

[nix]
channel = "stable-25_05"
