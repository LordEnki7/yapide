# Production environment variables for Capacitor / app-store builds.
# VITE_API_URL is baked into the JS bundle at build time via `vite build --mode production`.
#
# This URL is the live Replit deployment domain (verified via TLS certificate).
# If you add a custom domain (e.g. yapide.app), update this to: https://api.yapide.app
# and set SESSION_COOKIE_DOMAIN=.yapide.app in the project secrets.

VITE_API_URL=https://workspace-projectdna7.replit.app
